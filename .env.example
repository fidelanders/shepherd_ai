# ─── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Security ──────────────────────────────────────────────────
# Comma-separated list of allowed API keys for the X-API-Key header
API_KEYS=your-secret-key-here

# ─── Redis (required for job queue) ────────────────────────────
REDIS_URL=redis://localhost:6379
# For Upstash TLS use: rediss://default:password@host:6379

# ─── Transcription — OpenAI (online mode) ──────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── AI Insights — Google Gemini ───────────────────────────────
GEMINI_API_KEY=AIza...

# ─── Speaker Diarization — Hugging Face (pyannote-audio) ───────
HF_TOKEN=hf_...

# ─── Local Whisper.cpp (offline fallback) ──────────────────────
# Path to the whisper-cli binary (auto-detected by OS if not set)
# WHISPER_BIN=/path/to/whisper-cli
# WHISPER_MODEL=/path/to/ggml-base.bin

# ─── Force offline mode (skip OpenAI entirely) ─────────────────
# OFFLINE_MODE=true
